{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "composite": true,
    "noEmit": false,
    "paths": {
      "@schemly/core": ["../core/src/index.ts"],
      "@schemly/runtime": ["../runtime/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.vue"],
  "references": [
    { "path": "../core/tsconfig.json" },
    { "path": "../runtime/tsconfig.json" }
  ]
}
