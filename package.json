{
  "name": "schemly",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm -C playground dev",
    "build": "pnpm -r --filter='./packages/*' build",
    "build:core": "pnpm -C packages/core build",
    "build:runtime": "pnpm -C packages/runtime build",
    "build:designer": "pnpm -C packages/designer build",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --ext .ts,.tsx,.vue",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vitest/coverage-v8": "^3.0.0",
    "@vue/test-utils": "^2.4.6",
    "element-plus": "^2.9.0",
    "jsdom": "24",
    "typescript": "^5.7.0",
    "vite": "^6.2.0",
    "vitepress": "^1.6.4",
    "vitest": "^3.0.0",
    "vue": "^3.5.0",
    "vue-tsc": "^2.2.0"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=8"
  }
}
